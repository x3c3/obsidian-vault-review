{
  "name": "vault-review",
  "version": "1.0.2",
  "description": "Randomly review your vault and track progress",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "bun run build.ts --watch",
    "build": "bun run check && bun run build.ts",
    "check": "biome check src/",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "format:check": "biome format src/",
    "version": "bun run version-bump.ts",
    "test": "bun test",
    "deploy": "cp main.js manifest.json ~/source/philoserf/notes/.obsidian/plugins/vault-review/"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/bun": "^1.3.9",
    "@types/node": "^25.3.3",
    "obsidian": "^1.12.3",
    "typescript": "^5.9.3"
  }
}
